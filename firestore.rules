rules_version = '2';

// Security model
// - Custom claims are assigned only by scripts/provision-users.mjs (Firebase Admin SDK).
// - The browser may read its own profile, but can never choose or elevate a role.
// - Admin and HR are managers; employees can only access their own leave records.
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return signedIn() && request.auth.token.role == role;
    }

    function manager() {
      return hasRole('admin') || hasRole('hr');
    }

    function administrator() {
      return hasRole('admin');
    }

    function kiosk() {
      return hasRole('kiosk');
    }

    function ownEmployeeId() {
      return request.auth.token.get(
        'employeeId',
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('employeeId', request.auth.uid)
      );
    }

    function validAttendanceStatus(value) {
      return value in ['មានវត្តមាន', 'យឺត'];
    }

    function validSelfAttendance(data, recordId) {
      return data.uid == request.auth.uid
        && data.id == ownEmployeeId()
        && data.recordId == recordId
        && recordId == data.id + '_' + data.dateISO
        && validAttendanceStatus(data.status)
        && data.keys().hasAll(['id', 'recordId', 'uid', 'dateISO', 'name', 'branch', 'checkIn', 'checkInClientAt', 'status']);
    }

    function validSelfHistory(data, recordId) {
      return data.uid == request.auth.uid
        && data.id == ownEmployeeId()
        && data.docId == recordId
        && recordId == data.id + '_' + data.dateISO
        && validAttendanceStatus(data.status);
    }

    match /profiles/{userId} {
      allow get: if signedIn() && request.auth.uid == userId;
      allow list: if administrator();
      allow create, update, delete: if administrator();
    }

    // A login screen is not authenticated yet, so it can read one known
    // username document but can never list this directory. These documents
    // contain only the email needed by Firebase Email/Password Auth.
    match /usernames/{username} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if administrator();
    }

    // This minimal directory is used only before a password-reset email is
    // requested. It contains no passwords, profiles, roles, or employee data.
    // The Admin scripts keep it in sync with Firebase Authentication users.
    match /passwordResetEmails/{email} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if administrator();
    }

    match /employees/{employeeId} {
      allow get, list: if manager() || kiosk() || (signedIn() && resource.data.uid == request.auth.uid);
      allow create, update, delete: if manager();
    }

    // Immutable HR audit trail for transfers, promotions, job changes and
    // resignations. The Worker writes these records with a service account;
    // browser users can inspect them but cannot forge or rewrite history.
    match /employmentActions/{actionId} {
      allow get, list: if manager();
      allow create, update, delete: if false;
    }

    // Backend-only uniqueness reservations. They prevent concurrent requests
    // from reusing an employee email/phone or an HR decision number.
    match /employeeUnique/{reservationId} {
      allow read, write: if false;
    }

    match /decisionUnique/{reservationId} {
      allow read, write: if false;
    }

    // Transactional counter used to reserve unique employee numbers even
    // when two HR users add staff at the same time.
    match /counters/employees {
      allow get, create, update: if manager();
      allow list, delete: if false;
    }

    match /leaveRequests/{requestId} {
      allow get, list: if manager() || (signedIn() && resource.data.employeeUid == request.auth.uid);
      allow create: if hasRole('employee')
        && request.resource.data.employeeUid == request.auth.uid
        && request.resource.data.status == 'រង់ចាំពិនិត្យ'
        && request.resource.data.days is number
        && request.resource.data.days >= 1
        && request.resource.data.days <= 365
        && request.resource.data.keys().hasAll(['employeeUid', 'employeeId', 'name', 'branch', 'leaveType', 'startDate', 'endDate', 'days', 'reason', 'status']);
      allow update: if manager() || (
        hasRole('employee')
        && resource.data.employeeUid == request.auth.uid
        && request.resource.data.employeeUid == request.auth.uid
        && request.resource.data.status == 'រង់ចាំពិនិត្យ'
        && request.resource.data.status == resource.data.status
      );
      allow delete: if manager() || (
        hasRole('employee')
        && resource.data.employeeUid == request.auth.uid
        && resource.data.status == 'រង់ចាំពិនិត្យ'
      );
    }

    // A kiosk is a dedicated device account. It has no access to leave,
    // profiles, settings, roles, or employee administration.
    match /attendanceToday/{recordId} {
      // Employees use a stable per-day record ID and can only read/write the
      // record that contains their own UID. A query/list is deliberately not
      // exposed to employees, so they cannot enumerate other staff records.
      allow get: if manager() || kiosk() || (signedIn() && resource.data.uid == request.auth.uid);
      allow list: if manager() || kiosk();
      allow create: if manager() || kiosk() || (
        hasRole('employee')
        && validSelfAttendance(request.resource.data, recordId)
      );
      allow update: if manager() || kiosk() || (
        hasRole('employee')
        && validSelfAttendance(request.resource.data, recordId)
        && resource.data.uid == request.auth.uid
        && request.resource.data.id == resource.data.id
        && request.resource.data.recordId == resource.data.recordId
        && request.resource.data.dateISO == resource.data.dateISO
        && request.resource.data.name == resource.data.name
        && request.resource.data.branch == resource.data.branch
        && request.resource.data.checkIn == resource.data.checkIn
        && request.resource.data.checkInClientAt == resource.data.checkInClientAt
      );
      allow delete: if manager();
    }

    match /attendanceHistory/{recordId} {
      allow get, list, create, update, delete: if manager() || kiosk();
      allow get: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if hasRole('employee')
        && validSelfHistory(request.resource.data, recordId);
      allow update: if hasRole('employee')
        && resource.data.uid == request.auth.uid
        && validSelfHistory(request.resource.data, recordId)
        && request.resource.data.id == resource.data.id
        && request.resource.data.docId == resource.data.docId
        && request.resource.data.dateISO == resource.data.dateISO
        && request.resource.data.name == resource.data.name
        && request.resource.data.branch == resource.data.branch
        && request.resource.data.checkIn == resource.data.checkIn
        && request.resource.data.checkInClientAt == resource.data.checkInClientAt;
    }

    match /corrections/{recordId} {
      allow get, list, create, update, delete: if manager();
    }

    match /branches/{branchId} {
      allow get, list: if signedIn();
      allow create, update, delete: if manager();
    }

    match /{collectionName}/{documentId} {
      allow get, list, create, update, delete: if manager()
        && collectionName in ['departments', 'jobRoles', 'holidays'];
    }

    // The private document contains plaintext QR credentials and is never
    // exposed to employee accounts. Employees read only geofence requirements
    // and per-branch hashes/expiry values.
    match /settings/gpsQr {
      allow get: if manager();
      allow create, update: if manager();
      allow delete: if administrator();
    }

    match /settings/gpsQrPublic {
      allow get: if signedIn() || kiosk();
      allow list: if false;
      allow create, update: if manager();
      allow delete: if administrator();
    }

    match /qrTokens/{branchId} {
      allow get: if signedIn() || kiosk();
      allow list: if manager();
      allow create, update: if manager()
        && request.resource.data.branchId == branchId
        && request.resource.data.tokenHash is string
        && request.resource.data.tokenHash.size() == 64
        && request.resource.data.expiresAt is string;
      allow delete: if administrator();
    }

    match /settings/{settingId} {
      // Employees and a kiosk need the shift schedule only to calculate their
      // own attendance. Other settings remain manager-only.
      allow get: if manager() || kiosk() || (signedIn() && settingId == 'workingHours');
      allow create, update: if manager();
      allow delete: if administrator();
    }

    match /users/{userId} {
      allow get, list, create, update, delete: if administrator();
    }

    match /roles/{roleId} {
      allow get, list, create, update, delete: if administrator();
    }

    // Operational data used by the MFI management modules. Only HR/Admin
    // accounts can view or change these records; employee accounts never
    // receive salary, loan, KPI, or asset data.
    match /{collectionName}/{documentId} {
      allow get, list, create, update, delete: if manager()
        && collectionName in ['kpis', 'assets', 'staffLoans'];
    }

    // The Cloudflare Telegram Worker writes delivery logs with a Firebase
    // service account. Browser accounts can inspect logs but cannot forge a
    // successful delivery or modify the idempotency records.
    match /telegramOutbox/{messageId} {
      allow get, list: if manager();
      allow create, update, delete: if false;
    }

    match /telegramEvents/{eventId} {
      allow read, write: if false;
    }
  }
}
