rules_version = '2';

// This app has one login tier (staff who can sign in to the dashboard), so
// the rule is simple: you must be signed in with Firebase Auth to read or
// write anything. If you later add row-level permissions (e.g. employees
// can only edit their own leave requests), tighten the `write` rules for
// each collection individually — this is intentionally a safe starting
// point, not a finished permissions model.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
