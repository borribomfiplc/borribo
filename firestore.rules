rules_version = '2';

// Security model
// - Custom claims are assigned only by scripts/provision-users.mjs (Firebase Admin SDK).
// - The browser may read its own profile, but can never choose or elevate a role.
// - Admin and HR are managers; employees can only access their own leave records.
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function activeAccount() {
      return signedIn()
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('active', true) == true;
    }

    function hasRole(role) {
      return activeAccount() && request.auth.token.role == role;
    }

    function manager() {
      return hasRole('admin') || hasRole('hr');
    }

    function administrator() {
      return hasRole('admin');
    }

    // Attendance identity, date/time, GPS, QR and PIN validation are enforced
    // by the trusted Cloudflare Worker. Browser rules only permit reads.

    match /profiles/{userId} {
      allow get: if signedIn() && request.auth.uid == userId;
      allow list: if administrator();
      allow create, update, delete: if administrator();
    }

    // A login screen is not authenticated yet, so it can read one known
    // username document but can never list this directory. These documents
    // contain only the email needed by Firebase Email/Password Auth.
    match /usernames/{username} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if administrator();
    }

    // This minimal directory is used only before a password-reset email is
    // requested. It contains no passwords, profiles, roles, or employee data.
    // The Admin scripts keep it in sync with Firebase Authentication users.
    match /passwordResetEmails/{email} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if administrator();
    }

    match /employees/{employeeId} {
      // A kiosk must never download the employee directory or plaintext PINs.
      // It submits a PIN to the trusted Worker, which returns only the matched
      // employee's minimal display data after server-side verification.
      allow get, list: if manager() || (activeAccount() && resource.data.uid == request.auth.uid);
      allow create, update, delete: if manager();
    }

    // Immutable HR audit trail for transfers, promotions, job changes and
    // resignations. The Worker writes these records with a service account;
    // browser users can inspect them but cannot forge or rewrite history.
    match /employmentActions/{actionId} {
      allow get, list: if manager();
      allow create, update, delete: if false;
    }

    // Security-sensitive actions are written only by the trusted Worker.
    match /auditLogs/{logId} {
      allow get, list: if administrator();
      allow create, update, delete: if false;
    }

    // Backend-only uniqueness reservations. They prevent concurrent requests
    // from reusing an employee email/phone or an HR decision number.
    match /employeeUnique/{reservationId} {
      allow read, write: if false;
    }

    match /decisionUnique/{reservationId} {
      allow read, write: if false;
    }

    // Backend-only operational aggregates and uniqueness reservations.
    match /kpiWeightTotals/{bucketId} {
      allow read, write: if false;
    }

    match /payrollUnique/{reservationId} {
      allow read, write: if false;
    }

    // Transactional counter used to reserve unique employee numbers even
    // when two HR users add staff at the same time.
    match /counters/employees {
      allow get, create, update: if manager();
      allow list, delete: if false;
    }

    match /leaveRequests/{requestId} {
      allow get, list: if manager() || (activeAccount() && resource.data.employeeUid == request.auth.uid);
      allow create: if hasRole('employee')
        && request.resource.data.employeeUid == request.auth.uid
        && request.resource.data.status == 'រង់ចាំពិនិត្យ'
        && request.resource.data.days is number
        && request.resource.data.days >= 0.5
        && request.resource.data.days <= 365
        && request.resource.data.keys().hasAll(['employeeUid', 'employeeId', 'name', 'branch', 'leaveType', 'startDate', 'endDate', 'days', 'reason', 'status']);
      allow update: if manager() || (
        hasRole('employee')
        && resource.data.employeeUid == request.auth.uid
        && request.resource.data.employeeUid == request.auth.uid
        && resource.data.status == 'រង់ចាំពិនិត្យ'
        && request.resource.data.status in ['រង់ចាំពិនិត្យ', 'បានលុបចោល']
        && request.resource.data.employeeId == resource.data.employeeId
        && request.resource.data.startDate == resource.data.startDate
        && request.resource.data.endDate == resource.data.endDate
        && request.resource.data.days == resource.data.days
        && request.resource.data.leaveType == resource.data.leaveType
        && request.resource.data.reason == resource.data.reason
        && request.resource.data.name == resource.data.name
        && request.resource.data.branch == resource.data.branch
      );
      allow delete: if manager() || (
        hasRole('employee')
        && resource.data.employeeUid == request.auth.uid
        && resource.data.status == 'រង់ចាំពិនិត្យ'
      );
    }

    // Attendance writes from employee and kiosk browsers are forbidden.
    // The trusted Worker verifies identity, branch, PIN, GPS and QR, derives
    // Cambodia server time, and atomically writes today + history documents.
    // Manager writes remain temporarily enabled for the existing manual-entry
    // workflow; they should be migrated to the Worker in the next hardening pass.
    match /attendanceToday/{recordId} {
      allow get: if manager()
        || (activeAccount() && resource.data.uid == request.auth.uid);
      allow list: if manager();
      allow create, update, delete: if manager();
    }

    match /attendanceHistory/{recordId} {
      allow get: if manager()
        || (activeAccount() && resource.data.uid == request.auth.uid);
      allow list: if manager();
      allow create, update, delete: if manager();
    }

    match /corrections/{recordId} {
      allow get, list, create, update, delete: if manager();
    }

    match /branches/{branchId} {
      allow get, list: if activeAccount();
      allow create, update, delete: if manager();
    }

    match /holidays/{holidayId} {
      allow get, list: if activeAccount();
      allow create, update, delete: if manager();
    }

    match /{collectionName}/{documentId} {
      allow get, list, create, update, delete: if manager()
        && collectionName in ['departments', 'jobRoles', 'calendarEvents'];
    }

    // HR/Admin can append and inspect organization-transfer history, but
    // existing audit records cannot be rewritten or deleted from the browser.
    match /organizationChanges/{changeId} {
      allow get, list, create: if manager();
      allow update, delete: if false;
    }

    // The private document contains plaintext QR credentials and is never
    // exposed to employee accounts. Employees read only geofence requirements
    // and per-branch hashes/expiry values.
    match /settings/gpsQr {
      allow get: if manager();
      allow create, update: if manager();
      allow delete: if administrator();
    }

    match /settings/gpsQrPublic {
      allow get: if activeAccount();
      allow list: if false;
      allow create, update: if manager();
      allow delete: if administrator();
    }

    match /qrTokens/{branchId} {
      // QR token hashes are validated by the trusted Worker. Browsers no
      // longer need access to this collection.
      allow get, list: if manager();
      allow create, update: if manager()
        && request.resource.data.branchId == branchId
        && request.resource.data.tokenHash is string
        && request.resource.data.tokenHash.size() == 64
        && request.resource.data.expiresAt is string;
      allow delete: if administrator();
    }

    match /settings/company {
      // Company name, address and logo are displayed throughout the signed-in
      // app. Active accounts may read them; only Admin/HR may change them.
      allow get: if activeAccount();
      allow list: if false;
      allow create, update: if manager();
      allow delete: if administrator();
    }

    match /settings/systemPublic {
      // Runtime-safe settings used by every active account. Sensitive email
      // provider and backup metadata remain in manager-only settings/system.
      allow get: if activeAccount();
      allow list: if false;
      allow create, update: if manager();
      allow delete: if administrator();
    }

    match /settings/{settingId} {
      // This wildcard deliberately grants non-managers access only to the
      // working-hours document. It must never make settings/gpsQr readable.
      allow get: if manager()
        || (activeAccount() && settingId == 'workingHours');
      allow list: if false;
      allow create, update: if manager();
      allow delete: if administrator();
    }

    match /users/{userId} {
      allow get, list, create, update, delete: if administrator();
    }

    match /roles/{roleId} {
      allow get, list, create, update, delete: if administrator();
    }

    // Operational HR records contain approval, payment, assignment,
    // maintenance and KPI audit histories. Managers may read them, but all
    // writes go through the trusted Worker so browser users cannot forge,
    // rewrite or hard-delete financial/asset history.
    match /{collectionName}/{documentId} {
      allow get, list: if manager()
        && collectionName in ['kpis', 'assets', 'staffLoans', 'payrollRecords'];
      allow create, update, delete: if false;
    }

    // The Cloudflare Telegram Worker writes delivery logs with a Firebase
    // service account. Browser accounts can inspect logs but cannot forge a
    // successful delivery or modify the idempotency records.
    match /telegramOutbox/{messageId} {
      allow get, list: if manager();
      allow create, update, delete: if false;
    }

    match /telegramEvents/{eventId} {
      allow read, write: if false;
    }
  }
}
